# Optional: Anthropic API key (not needed if using `claude login` subscription)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub PAT for cloning private repos
# GITHUB_TOKEN=ghp_...

# Optional: Bearer token to protect the orchestrator API
# API_KEY=my-secret-token

# Server configuration
# PORT=8080
# DATA_DIR=/opt/ralph-orchestrator/data
# LOG_LEVEL=info
# CLONE_TIMEOUT=5m
# SHUTDOWN_TIMEOUT=30s
